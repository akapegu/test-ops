{
  "family": "housing-api-task-ecs",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::533850701609:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::533850701609:role/ecs_s3_access",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "3072",
  "containerDefinitions": [
    {
      "name": "housing-api",
      "image": "533850701609.dkr.ecr.eu-north-1.amazonaws.com/housing-api:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "S3_BUCKET",
          "value": "housing-regression-data-pegu"
        },
        {
          "name": "AWS_REGION",
          "value": "eu-north-1"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/housing-api-task-ecs",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
