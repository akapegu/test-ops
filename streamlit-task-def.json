{
  "family": "housing-streamlit",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::533850701609:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::533850701609:role/ecs_s3_access",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "containerDefinitions": [
    {
      "name": "housing-streamlit",
      "image": "533850701609.dkr.ecr.eu-north-1.amazonaws.com/housing-streamlit:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8501,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "STREAMLIT_SERVER_PORT",
          "value": "8501"
        },
        {
          "name": "STREAMLIT_SERVER_ADDRESS",
          "value": "0.0.0.0"
        },
        {
          "name": "STREAMLIT_SERVER_BASEURLPATH",
          "value": "/dashboard"
        },
        {
          "name": "STREAMLIT_BROWSER_GATHERUSAGESTATS",
          "value": "false"
        },
        {
          "name": "S3_BUCKET",
          "value": "housing-regression-data-pegu"
        },
        {
          "name": "AWS_REGION",
          "value": "eu-north-1"
        },
        {
          "name": "API_URL",
          "value": "http://REPLACE_WITH_YOUR_ALB_DNS/predict"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/housing-streamlit",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
